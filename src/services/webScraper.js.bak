// Method: JSON API (GET) — real working public API
async function scrapeUnstop() {
    try {
        const response = await axios.get('https://unstop.com/api/public/opportunity', {
            params: { type: 'job', 'opportunity-type': 'Fresher Job', page: 1, per_page: 50 },
            timeout: 15000,
            headers: COMMON_HEADERS
        });
        const jobs = response.data?.data?.opportunities || response.data?.opportunities || [];
        return jobs.map(job => ({
            title: job.title,
            company_name: job.organisation?.name || job.company || 'Company',
            location: job.location || 'India',
            description: job.description || job.short_description || '',
            url: job.public_url || `https://unstop.com/o/${job.id}`,
            slug: String(job.id || `unstop_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
            job_type: job.type || 'Fresher Job',
            date: job.start_timestamp || job.created_at || null,
            source: 'Unstop'
        }));
    } catch (e) {
        console.warn('Unstop scraper failed:', e.message);
        return [];
    }
}

// Method: HTML scrape (regex-based)
async function scrapeInternshalaJobs() {
    try {
        const response = await axios.get('https://internshala.com/jobs/cloud-computing-jobs,cyber-security-jobs,devops-jobs/', {
            timeout: 15000,
            headers: {
                'User-Agent': UA,
                'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
            }
        });
        const html = typeof response.data === 'string' ? response.data : '';
        if (!html) return [];

        const jobs = [];
        // Extract job cards using regex
        const titleRegex = /<a[^>]*class="[^"]*job-title[^"]*"[^>]*href="([^"]*)"[^>]*>\s*([^<]+)/gi;
        const companyRegex = /<a[^>]*class="[^"]*company-name[^"]*"[^>]*>\s*([^<]+)/gi;
        const locationRegex = /<span[^>]*class="[^"]*location[^"]*"[^>]*>\s*([^<]+)/gi;

        let titleMatch;
        const titles = [];
        const urls = [];
        while ((titleMatch = titleRegex.exec(html)) !== null) {
            urls.push(titleMatch[1]);
            titles.push(titleMatch[2].trim());
        }

        const companies = [];
        let companyMatch;
        while ((companyMatch = companyRegex.exec(html)) !== null) {
            companies.push(companyMatch[1].trim());
        }

        const locations = [];
        let locationMatch;
        while ((locationMatch = locationRegex.exec(html)) !== null) {
            locations.push(locationMatch[1].trim());
        }

        for (let i = 0; i < titles.length; i++) {
            jobs.push({
                title: titles[i],
                company_name: companies[i] || 'Company',
                location: locations[i] || 'India',
                description: '',
                url: urls[i]?.startsWith('http') ? urls[i] : `https://internshala.com${urls[i] || ''}`,
                slug: `internshala_job_${i}_${Date.now()}`,
                date: null,
                source: 'Internshala Jobs'
            });
        }
        return jobs;
    } catch (e) {
        console.warn('Internshala Jobs scraper failed:', e.message);
        return [];
    }
}

// Method: JSON API (GET)
async function scrapeNaukriCampus() {
    try {
        const response = await axios.get('https://campus.naukri.com/api/v1/job/search', {
            params: { keywords: 'cloud azure devops', experience: 0, location: 'India' },
            timeout: 15000,
            headers: COMMON_HEADERS
        });
        if (typeof response.data === 'object' && response.data !== null) {
            const jobs = response.data?.jobs || response.data?.data || response.data?.results || [];
            return jobs.map(job => ({
                title: job.title || job.jobTitle,
                company_name: job.companyName || job.company || 'Company',
                location: job.location || 'India',
                description: job.description || job.jobDescription || '',
                url: job.url || job.applyUrl || `https://campus.naukri.com/job/${job.id}`,
                slug: String(job.id || `naukricampus_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
                date: job.postedDate || job.createdAt || null,
                source: 'Naukri Campus'
            }));
        }
        return [];
    } catch (e) {
        console.warn('Naukri Campus scraper failed:', e.message);
        return [];
    }
}

// ============================================================================
// HTML PARSING UTILITY (regex-based, no cheerio)
// ============================================================================

/**
 * Extract jobs from raw HTML using regex patterns
 * Fallback for career pages that return HTML instead of JSON
 */
function extractJobsFromHTML(html, companyName, baseUrl, sourceName) {
    if (!html || typeof html !== 'string') return [];

    const jobs = [];
    // Common patterns: <a href="/job/...">Job Title</a>
    const linkRegex = /<a[^>]*href="([^"]*(?:job|career|position|opening|vacancy)[^"]*)"[^>]*>([^<]{5,100})<\/a>/gi;
    let match;
    const seen = new Set();

    while ((match = linkRegex.exec(html)) !== null) {
        const href = match[1];
        const title = match[2].trim().replace(/&amp;/g, '&').replace(/&#\d+;/g, '');

        // Skip navigation links, pagination, etc.
        if (title.length < 5 || /next|prev|page|login|sign|menu|nav|cookie/i.test(title)) continue;
        if (seen.has(href)) continue;
        seen.add(href);

        const fullUrl = href.startsWith('http') ? href : `${baseUrl}${href.startsWith('/') ? '' : '/'}${href}`;
        jobs.push({
            title,
            company_name: companyName,
            location: 'India',
            description: '',
            url: fullUrl,
            slug: `${companyName.toLowerCase().replace(/\s+/g, '_')}_${Buffer.from(href).toString('base64').slice(0, 12)}`,
            date: null,
            source: sourceName
        });
    }
    return jobs;
}

// ============================================================================
// TEST ALL SCRAPERS
// ============================================================================

async function testAllScrapers() {
    const scrapers = [
        { name: 'TCS', fn: scrapeTCS },
        { name: 'Infosys', fn: scrapeInfosys },
        { name: 'Wipro', fn: scrapeWipro },
        { name: 'Cognizant', fn: scrapeCognizant },
        { name: 'HCL Technologies', fn: scrapeHCL },
        { name: 'Tech Mahindra', fn: scrapeTechMahindra },
        { name: 'Capgemini', fn: scrapeCapgemini },
        { name: 'Mphasis', fn: scrapeMphasis },
        { name: 'Hexaware', fn: scrapeHexaware },
        { name: 'LTIMindtree', fn: scrapeLTIMindtree },
        { name: 'Accenture', fn: scrapeAccentureJobs },
        { name: 'IBM', fn: scrapeIBM },
        { name: 'Deloitte', fn: scrapeDeloitte },
        { name: 'EY', fn: scrapeEY },
        { name: 'DXC Technology', fn: scrapeDXC },
        { name: 'Google', fn: scrapeGoogleCareers },
        { name: 'Microsoft', fn: scrapeMicrosoftCareers },
        { name: 'Amazon', fn: scrapeAmazonJobs },
        { name: 'Oracle', fn: scrapeOracleJobs },
        { name: 'Unstop', fn: scrapeUnstop },
        { name: 'Internshala Jobs', fn: scrapeInternshalaJobs },
        { name: 'Naukri Campus', fn: scrapeNaukriCampus },
    ];

    console.log('\n🔍 Testing all career page scrapers...\n');
    let totalJobs = 0;
    let successCount = 0;

    for (const { name, fn } of scrapers) {
        try {
            const startTime = Date.now();
            const jobs = await fn();
            const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
            if (jobs.length > 0) {
                console.log(`  ✅ ${name} → ${jobs.length} jobs (${elapsed}s)`);
                successCount++;
                totalJobs += jobs.length;
            } else {
                console.log(`  ⚠️  ${name} → 0 jobs (${elapsed}s)`);
            }
        } catch (err) {
            console.log(`  ❌ ${name} → error: ${err.message}`);
        }
    }

    console.log(`\n📊 Summary: ${successCount}/${scrapers.length} scrapers returned jobs, ${totalJobs} total jobs\n`);
}

if (require.main === module) {
    testAllScrapers();
}

