            // Fallback to main career page
            response = await axios.get('https://www.hcltech.com/careers/job-search', {
                params: { skill: 'cloud', location: 'India' },
                timeout: 15000,
                headers: COMMON_HEADERS
            });
        }
        if (typeof response.data === 'object' && response.data !== null) {
            const jobs = response.data?.jobs || response.data?.results || response.data?.data || [];
            return jobs.map(job => ({
                title: job.title || job.jobTitle,
                company_name: 'HCL Technologies',
                location: job.location || 'India',
                description: job.description || job.jobDescription || '',
                url: job.jobUrl || job.url || `https://www.hcltech.com/careers/job/${job.id}`,
                slug: String(job.id || `hcl_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
                date: job.postedDate || null,
                source: 'HCL Careers'
            }));
        }
        const html = typeof response.data === 'string' ? response.data : '';
        return extractJobsFromHTML(html, 'HCL Technologies', 'https://www.hcltech.com', 'HCL Careers');
    } catch (e) {
        console.warn('HCL scraper failed:', e.message);
        return [];
    }
}

