// Method: JSON API (POST)
async function scrapeTCS() {
    try {
        const response = await axios.post('https://ibegin.tcs.com/iBegin/jobs/search',
            { keywords: 'cloud azure devops security', location: '', pageNo: 1, pageSize: 50 },
            { timeout: 15000, headers: { 'Content-Type': 'application/json', 'User-Agent': UA } }
        );
        const jobs = response.data?.jobs || response.data?.data || [];
        return jobs.map(job => ({
            title: job.title || job.jobTitle,
            company_name: 'TCS',
            location: job.location || 'India',
            description: job.description || '',
            url: job.url || `https://ibegin.tcs.com/iBegin/jobs/${job.id}`,
            slug: String(job.id || `tcs_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
            date: job.postedDate || null,
            source: 'TCS Careers'
        }));
    } catch (e) {
        console.warn('TCS scraper failed:', e.message);
        return [];
    }
}

// Method: JSON API (GET)
async function scrapeInfosys() {
    try {
        const response = await axios.get('https://career.infosys.com/joblist', {
            params: { location: 'India', limit: 50 },
            timeout: 15000,
            headers: COMMON_HEADERS
        });
        if (typeof response.data === 'object' && response.data !== null) {
            const jobs = response.data?.jobPostings || response.data?.jobs || response.data?.data || [];
            return jobs.map(job => ({
                title: job.title || job.jobTitle,
                company_name: 'Infosys',
                location: job.location || job.jobLocation || 'India',
                description: job.description || job.jobDescription || '',
                url: job.jobUrl || job.url || `https://career.infosys.com/jobdesc?jobReferenceCode=${job.jobReferenceCode || job.id}`,
                slug: String(job.id || job.jobReferenceCode || `infosys_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
                date: job.postedDate || null,
                source: 'Infosys Careers'
            }));
        }
        // Fallback: HTML scrape for job links
        const html = typeof response.data === 'string' ? response.data : '';
        return extractJobsFromHTML(html, 'Infosys', 'https://career.infosys.com', 'Infosys Careers');
    } catch (e) {
        console.warn('Infosys scraper failed:', e.message);
        return [];
    }
}

