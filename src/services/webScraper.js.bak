/**
 * Web scraper service for company career pages
 * Scrapes Indian IT consultancies, MNCs, and fresher platforms
 * Uses only axios — no cheerio dependency
 */

const axios = require('axios');

const UA = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36';

const COMMON_HEADERS = {
    'User-Agent': UA,
    'Accept': 'application/json, text/html, */*',
    'Accept-Language': 'en-US,en;q=0.9',
};

// ============================================================================
// GENERIC WORKDAY SCRAPER (used by DXC, Mphasis, Capgemini, etc.)
// ============================================================================

// Method: Workday POST API
async function scrapeWorkday(tenantName, jobBoardId, companyDisplayName, keywords = 'cloud azure devops') {
    try {
        const url = `https://${tenantName}.wd1.myworkdayjobs.com/wday/cxs/${tenantName}/${jobBoardId}/jobs`;
        const body = { limit: 20, offset: 0, searchText: keywords, locations: [] };
        const response = await axios.post(url, body, {
            timeout: 15000,
            headers: { 'Content-Type': 'application/json', 'User-Agent': UA }
        });
        const jobs = response.data?.jobPostings || [];
        return jobs.map(job => ({
            title: job.title || job.bulletFields?.[0],
            company_name: companyDisplayName,
            location: job.locationsText || 'India',
            description: job.descriptionTeaser || '',
            url: `https://${tenantName}.wd1.myworkdayjobs.com/en-US/${jobBoardId}${job.externalPath}`,
            slug: job.bulletFields?.[1] || `${tenantName}_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
            date: job.postedOn || null,
            source: `${companyDisplayName} Careers`
        }));
    } catch (e) {
        console.warn(`${companyDisplayName} Workday scraper failed:`, e.message);
        return [];
    }
}

// ============================================================================
// INDIAN IT CONSULTANCIES
