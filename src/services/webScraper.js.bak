// Method: Workday POST API
async function scrapeCapgemini() {
    try {
        // Try Workday endpoint first (Capgemini uses Workday)
        const workdayJobs = await scrapeWorkday('capgemini', 'Capgemini_Careers', 'Capgemini', 'cloud azure devops');
        if (workdayJobs.length > 0) return workdayJobs;

        // Fallback: try their own API
        const response = await axios.get('https://www.capgemini.com/in-en/careers/job-search/', {
            params: { query: 'cloud azure', country: 'IN' },
            timeout: 15000,
            headers: COMMON_HEADERS
        });
        if (typeof response.data === 'object' && response.data !== null) {
            const jobs = response.data?.jobs || response.data?.results || [];
            return jobs.map(job => ({
                title: job.title || job.jobTitle,
                company_name: 'Capgemini',
                location: job.location || 'India',
                description: job.description || '',
                url: job.applyUrl || job.url || `https://www.capgemini.com/careers/job/${job.id}`,
                slug: String(job.id || `capgemini_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
                date: job.postedDate || null,
                source: 'Capgemini Careers'
            }));
        }
        return [];
    } catch (e) {
        console.warn('Capgemini scraper failed:', e.message);
        return [];
    }
}

