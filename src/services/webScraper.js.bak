// Method: JSON API (POST)
async function scrapeAccentureJobs() {
    try {
        const response = await axios.post('https://www.accenture.com/api/sitecore/CareerSearchAjax/GetJobs', {
            Keywords: 'cloud azure devops security',
            Location: 'India',
            PageNumber: 1,
            PageSize: 50,
            Language: 'en'
        }, {
            timeout: 15000,
            headers: { 'Content-Type': 'application/json', 'User-Agent': UA }
        });
        const jobs = response.data?.Results || response.data?.jobs || response.data?.data || [];
        return jobs.map(job => ({
            title: job.Title || job.title || job.jobTitle,
            company_name: 'Accenture',
            location: job.Location || job.location || 'India',
            description: job.Description || job.description || '',
            url: job.ApplyUrl || job.DetailUrl || `https://www.accenture.com/in-en/careers/jobdetails?id=${job.Id || job.id}`,
            slug: String(job.Id || job.id || `accenture_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`),
            date: job.PostedDate || job.postedDate || null,
            source: 'Accenture India'
        }));
    } catch (e) {
        console.warn('Accenture scraper failed:', e.message);
        return [];
    }
}

