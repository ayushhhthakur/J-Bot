            slug: job.Id || job.RequisitionId,
            job_type: job.JobType || 'Full-time',
            date: job.PostedDate || null,
            source: 'Oracle India'
        }));
    } catch (e) {
        console.warn('Oracle scraping failed:', e.message);
        return [];
    }
}

